<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EarthBackground.ViewModels"
        xmlns:controls="using:EarthBackground.Controls"
        xmlns:converters="using:EarthBackground.Converters"
        x:Class="EarthBackground.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="False"
        Title="{Binding WindowTitle}"
        Width="480" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/earth.ico">

    <Window.Resources>
        <converters:ButtonLabelConverter x:Key="ButtonLabelConverter" />
        <converters:MultiplyConverter x:Key="ButtonTextWidthConverter" Factor="0.7" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.mainActionButton">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.mainActionButton:disabled">
            <Setter Property="Opacity" Value="0.7" />
        </Style>
        <Style Selector="Button.mainActionButton TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="80,*">

        <!-- Header Panel -->
        <Panel Grid.Row="0" Background="#2980B9">
            <controls:AnimatedGifImage
                AssetPath="avares://EarthBackground/Assets/Rotating_earth_animated_transparent.gif"
                DecodeWidth="58"
                Width="58" Height="58"
                Margin="11,11,0,0"
                Stretch="Uniform"
                HorizontalAlignment="Left"
                VerticalAlignment="Top" />
            <TextBlock
                Text="{Binding HeaderTitle}"
                FontFamily="Segoe UI"
                FontSize="18"
                FontWeight="Bold"
                Foreground="White"
                VerticalAlignment="Center"
                Margin="90,0,0,0" />
        </Panel>

        <!-- Main Content -->
        <Grid Grid.Row="1" Background="#F8F9FA" Margin="20">
            <Grid RowDefinitions="*,Auto">

                <!-- Status Panel -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="20"
                        Margin="0,0,0,10">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="{Binding StatusText}"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Foreground="#34495E" />
                        <ProgressBar
                            Value="{Binding ProgressValue}"
                            Maximum="{Binding ProgressMax}"
                            Height="20"
                            Foreground="#2ECC71"
                            Background="#ECF0F1" />
                        <TextBlock
                            Text="{Binding ProgressText}"
                            FontFamily="Segoe UI"
                            FontSize="9"
                            HorizontalAlignment="Center"
                            Foreground="#95A5A6" />
                    </StackPanel>
                </Border>

                <!-- Buttons Panel -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        Padding="20,10">
                    <Grid ColumnDefinitions="*,10,*,10,*,10,*">
                        <Button
                            Grid.Column="0"
                            Classes="mainActionButton"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding CanStart}"
                            Background="#2ECC71"
                            Foreground="#FFFFFF">
                            <TextBlock
                                Text="{Binding BtnStart, Converter={StaticResource ButtonLabelConverter}}"
                                Width="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ButtonTextWidthConverter}}" />
                        </Button>
                        <Button
                            Grid.Column="2"
                            Classes="mainActionButton"
                            Command="{Binding StopCommand}"
                            IsEnabled="{Binding CanStop}"
                            Background="#E74C3C">
                            <TextBlock
                                Text="{Binding BtnStop, Converter={StaticResource ButtonLabelConverter}}"
                                Width="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ButtonTextWidthConverter}}" />
                        </Button>
                        <Button
                            Grid.Column="4"
                            Classes="mainActionButton"
                            Command="{Binding SettingsCommand}"
                            Background="#3498DB">
                            <TextBlock
                                Text="{Binding BtnSettings, Converter={StaticResource ButtonLabelConverter}}"
                                Width="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ButtonTextWidthConverter}}" />
                        </Button>
                        <Button
                            Grid.Column="6"
                            Classes="mainActionButton"
                            Command="{Binding ExitCommand}"
                            Background="#95A5A6">
                            <TextBlock
                                Text="{Binding BtnExit, Converter={StaticResource ButtonLabelConverter}}"
                                Width="{Binding Bounds.Width, RelativeSource={RelativeSource AncestorType=Button}, Converter={StaticResource ButtonTextWidthConverter}}" />
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

    </Grid>

</Window>
